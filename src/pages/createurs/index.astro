---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import creatorsData from '../../data/creators.json';

const articles = await getCollection('articles');
const creators = creatorsData.creators.map((c) => ({
  ...c,
  articleCount: articles.filter((a) => a.data.creatorHandle === c.handle).length,
}));
---
<BaseLayout title="Les créateurs" description="Les 5 créateurs IA suivis sur Les GOATs de l'IA.">
  <section class="section">
    <div class="container">
      <h1>Les 5 GOATs de l'IA</h1>
      <p style="color: var(--fg-muted); max-width: 640px;">
        Les créateurs que nous suivons et dont chaque vidéo est analysée pour devenir un article.
      </p>
      <div class="creators-grid" style="margin-top: 2rem;">
        {creators.map((c) => (
          <a href={c.url} target="_blank" rel="noopener" class="creator-card" style="text-decoration: none; color: inherit; border-bottom: none;">
            <div style="font-size: 2.4rem">{c.platform === 'youtube' ? '📺' : '🎵'}</div>
            <h3>{c.name}</h3>
            <div class="creator-handle">{c.handle}</div>
            <p>{c.bio}</p>
            <div style="margin-top: 0.7rem; font-size: 0.85rem;">
              <span class="tag">{c.platform === 'youtube' ? 'YouTube' : 'TikTok'}</span>
              <span class="tag">{c.articleCount} article{c.articleCount > 1 ? 's' : ''}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
