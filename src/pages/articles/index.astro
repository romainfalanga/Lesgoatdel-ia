---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleCard from '../../components/ArticleCard.astro';

const articles = (await getCollection('articles')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---
<BaseLayout title="Tous les articles" description="Tous les articles générés à partir des vidéos des GOATs de l'IA.">
  <section class="section">
    <div class="container">
      <div class="section-head">
        <h2>Tous les articles</h2>
        <span style="color: var(--fg-muted); font-size: 0.95rem">
          {articles.length} article{articles.length > 1 ? 's' : ''}
        </span>
      </div>
      {articles.length === 0 ? (
        <p style="color: var(--fg-muted)">Pas encore d'article publié.</p>
      ) : (
        <div class="grid">
          {articles.map((a) => (
            <ArticleCard
              href={`/articles/${a.slug}/`}
              title={a.data.title}
              description={a.data.description}
              pubDate={a.data.pubDate}
              creator={a.data.creator}
              platform={a.data.platform}
              thumbnail={a.data.thumbnail}
            />
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
