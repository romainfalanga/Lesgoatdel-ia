---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const recaps = await getCollection('recaps');
  return recaps.map((recap) => ({
    params: { slug: recap.slug },
    props: { recap },
  }));
}

const { recap } = Astro.props;
const { Content } = await recap.render();
const dateStr = recap.data.pubDate.toLocaleDateString('fr-FR', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
const periodLabels = { daily: 'quotidien', weekly: 'hebdomadaire', monthly: 'mensuel' } as const;
---
<BaseLayout title={recap.data.title} description={recap.data.description}>
  <article class="article-page">
    <div class="container" style="max-width: 760px;">
      <div class="article-meta">
        <span class="tag">Récap {periodLabels[recap.data.period]}</span>
        <span>{dateStr}</span>
      </div>
      <h1>{recap.data.title}</h1>
      <div class="recap-banner">
        <strong>{recap.data.videoCount}</strong> vidéo{recap.data.videoCount > 1 ? 's' : ''}
        de <strong>{recap.data.creatorCount}</strong> créateur{recap.data.creatorCount > 1 ? 's' : ''} :
        {' '}{recap.data.creators.join(', ')}.
      </div>
      <div class="article-content">
        <Content />
      </div>
      {recap.data.model && (
        <div class="article-footer">
          <div style="font-size: 0.82rem; opacity: 0.7;">
            Récap généré par {recap.data.model} via OpenRouter.
          </div>
        </div>
      )}
    </div>
  </article>
</BaseLayout>
