---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import CreatorAvatar from '../components/CreatorAvatar.astro';
import TimelineItem from '../components/TimelineItem.astro';
import creatorsData from '../data/creators.json';

const articles = await getCollection('articles');
const recaps = await getCollection('recaps');

type FeedEntry =
  | {
      kind: 'article';
      pubDate: Date;
      slug: string;
      title: string;
      description: string;
      creator: string;
      platform: 'youtube' | 'tiktok';
      thumbnail?: string;
    }
  | {
      kind: 'recap';
      pubDate: Date;
      slug: string;
      title: string;
      description: string;
      period: 'daily' | 'weekly' | 'monthly';
      creatorCount: number;
      videoCount: number;
    };

const feed: FeedEntry[] = [
  ...articles.map((a) => ({
    kind: 'article' as const,
    pubDate: a.data.pubDate,
    slug: a.slug,
    title: a.data.title,
    description: a.data.description,
    creator: a.data.creator,
    platform: a.data.platform,
    thumbnail: a.data.thumbnail,
  })),
  ...recaps.map((r) => ({
    kind: 'recap' as const,
    pubDate: r.data.pubDate,
    slug: r.slug,
    title: r.data.title,
    description: r.data.description,
    period: r.data.period,
    creatorCount: r.data.creatorCount,
    videoCount: r.data.videoCount,
  })),
];

feed.sort((a, b) => b.pubDate.valueOf() - a.pubDate.valueOf());

const creators = creatorsData.creators;
---
<BaseLayout>
  <section class="hero">
    <div class="container">
      <h1>
        Les <span class="accent">GOATs de l'IA</span>
      </h1>
      <div class="hero-goats">
        <div class="hero-row hero-row--tiktok" role="list">
          {creators.filter((c) => c.platform === 'tiktok').map((c) => (
            <CreatorAvatar
              name={c.name}
              handle={c.handle}
              platform={c.platform as 'youtube' | 'tiktok'}
              avatar={c.avatar || undefined}
              socialUrl={c.socialUrl}
            />
          ))}
        </div>
        <div class="hero-row hero-row--youtube" role="list">
          {creators.filter((c) => c.platform === 'youtube').map((c) => (
            <CreatorAvatar
              name={c.name}
              handle={c.handle}
              platform={c.platform as 'youtube' | 'tiktok'}
              avatar={c.avatar || undefined}
              socialUrl={c.socialUrl}
            />
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="timeline-section">
    <div class="container">
      <div class="timeline-head">
        <h2>Timeline</h2>
        <span class="timeline-count">
          {feed.length} entrée{feed.length > 1 ? 's' : ''}
        </span>
      </div>

      {feed.length === 0 ? (
        <p style="color: var(--fg-muted)">
          La timeline est vide pour l'instant. Elle se remplira automatiquement
          dès qu'un des GOATs publiera une vidéo.
        </p>
      ) : (
        <ol class="timeline">
          {feed.map((entry) => (
            entry.kind === 'article' ? (
              <TimelineItem
                kind="article"
                href={`/articles/${entry.slug}/`}
                title={entry.title}
                description={entry.description}
                pubDate={entry.pubDate}
                creator={entry.creator}
                platform={entry.platform}
                thumbnail={entry.thumbnail}
              />
            ) : (
              <TimelineItem
                kind="recap"
                href={`/recaps/${entry.slug}/`}
                title={entry.title}
                description={entry.description}
                pubDate={entry.pubDate}
                period={entry.period}
                creatorCount={entry.creatorCount}
                videoCount={entry.videoCount}
              />
            )
          ))}
        </ol>
      )}
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    padding: 4rem 0 3.5rem;
    border-bottom: 1px solid var(--border);
  }
  .hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.8rem);
    margin: 0 auto 2.4rem;
    text-align: center;
    max-width: 820px;
  }
  .hero-goats {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
    max-width: 720px;
    margin: 0 auto;
  }
  .hero-row {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 1.6rem;
    flex-wrap: wrap;
  }
  @media (max-width: 720px) {
    .hero-goats { gap: 1.2rem; }
    .hero-row { gap: 1.1rem; }
  }

  .timeline-section {
    padding: 3rem 0 4rem;
  }
  .timeline-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 2rem;
  }
  .timeline-head h2 {
    margin: 0;
  }
  .timeline-count {
    color: var(--fg-muted);
    font-size: 0.95rem;
  }
  .timeline {
    position: relative;
    list-style: none;
    margin: 0;
    padding: 0 0 0 88px;
  }
  /* The vertical line of the timeline */
  .timeline::before {
    content: '';
    position: absolute;
    left: 100px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(180deg,
      transparent 0%,
      var(--border) 4%,
      var(--border) 96%,
      transparent 100%);
  }
  @media (max-width: 720px) {
    .timeline {
      padding-left: 0;
    }
    .timeline::before {
      left: 7px;
    }
    .timeline-section {
      padding: 1.5rem 0 3rem;
    }
    .timeline-head {
      margin-bottom: 1rem;
    }
  }
</style>
