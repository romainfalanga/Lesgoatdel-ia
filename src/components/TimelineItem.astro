---
export interface Props {
  href: string;
  title: string;
  description: string;
  pubDate: Date;
  kind: 'article' | 'recap';
  // article fields
  creator?: string;
  platform?: 'youtube' | 'tiktok';
  thumbnail?: string;
  // recap fields
  period?: 'daily' | 'weekly' | 'monthly';
  creatorCount?: number;
  videoCount?: number;
}

const {
  href,
  title,
  description,
  pubDate,
  kind,
  creator,
  platform,
  thumbnail,
  period,
  creatorCount,
  videoCount,
} = Astro.props;

const dayStr = pubDate.toLocaleDateString('fr-FR', {
  day: '2-digit',
  month: 'short',
});
const timeStr = pubDate.toLocaleTimeString('fr-FR', {
  hour: '2-digit',
  minute: '2-digit',
});
const platformLabel = platform === 'youtube' ? 'YouTube' : platform === 'tiktok' ? 'TikTok' : '';
const periodLabel =
  period === 'daily' ? 'Récap quotidien' :
  period === 'weekly' ? 'Récap hebdo' :
  period === 'monthly' ? 'Récap mensuel' : '';
---
<li class={`tl-item tl-item--${kind}`}>
  <div class="tl-when">
    <span class="tl-day">{dayStr}</span>
    <span class="tl-time">{timeStr}</span>
  </div>
  <span class={`tl-dot tl-dot--${kind} ${platform ? `tl-dot--${platform}` : ''}`} aria-hidden="true"></span>
  <a class="tl-card" href={href}>
    {kind === 'article' && thumbnail && (
      <div class="tl-thumb" style={`background-image: url('${thumbnail}')`}>
        {platform && <span class={`tl-badge tl-badge--${platform}`}>{platformLabel}</span>}
      </div>
    )}
    {kind === 'article' && !thumbnail && platform && (
      <div class="tl-thumb tl-thumb--placeholder">
        <span class={`tl-badge tl-badge--${platform}`}>{platformLabel}</span>
      </div>
    )}
    <div class="tl-body">
      <div class="tl-meta">
        <span class="tl-mobile-date" aria-hidden="true">{dayStr}</span>
        {kind === 'article' ? (
          <>
            <span class="tl-creator">{creator}</span>
          </>
        ) : (
          <>
            <span class="tl-tag">{periodLabel}</span>
            <span class="tl-creator">{videoCount} vidéo{videoCount && videoCount > 1 ? 's' : ''} · {creatorCount} créateur{creatorCount && creatorCount > 1 ? 's' : ''}</span>
          </>
        )}
      </div>
      <h3 class="tl-title">{title}</h3>
      <p class="tl-desc">{description}</p>
    </div>
  </a>
</li>

<style>
  .tl-item {
    position: relative;
    display: grid;
    grid-template-columns: 88px 24px 1fr;
    gap: 0;
    padding: 0.9rem 0;
    align-items: stretch;
  }
  .tl-when {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    justify-content: flex-start;
    padding: 0.55rem 1rem 0 0;
    color: var(--fg-muted);
  }
  .tl-day {
    font-size: 0.92rem;
    font-weight: 700;
    color: var(--fg);
    text-transform: uppercase;
    letter-spacing: 0.02em;
  }
  .tl-time {
    font-size: 0.78rem;
    margin-top: 0.1rem;
  }
  .tl-dot {
    position: relative;
    width: 12px;
    height: 12px;
    border-radius: 50%;
    background: var(--accent);
    margin-top: 0.85rem;
    margin-left: 6px;
    box-shadow: 0 0 0 4px rgba(255, 210, 63, 0.15);
  }
  .tl-dot--recap {
    background: var(--accent-2);
    box-shadow: 0 0 0 4px rgba(192, 132, 252, 0.18);
  }
  .tl-dot--youtube { background: #ff3344; box-shadow: 0 0 0 4px rgba(255,51,68,0.18); }
  .tl-dot--tiktok  { background: #25f4ee; box-shadow: 0 0 0 4px rgba(37,244,238,0.18); }
  .tl-card {
    display: flex;
    gap: 1rem;
    background: var(--bg-elev);
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
    margin-left: 1.2rem;
    color: inherit;
    text-decoration: none;
    border-bottom: 1px solid var(--border) !important;
    transition: transform 160ms ease, border-color 160ms ease;
  }
  .tl-card:hover {
    transform: translateX(3px);
    border-color: var(--accent);
  }
  .tl-thumb {
    flex: 0 0 200px;
    aspect-ratio: 16 / 9;
    background-size: cover;
    background-position: center;
    background-color: var(--bg-elev-2);
    position: relative;
  }
  .tl-thumb--placeholder {
    background: linear-gradient(135deg, #1f1f2c, #14141d);
  }
  .tl-badge {
    position: absolute;
    top: 0.5rem;
    left: 0.5rem;
    background: rgba(0,0,0,0.7);
    color: #fff;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }
  .tl-badge--youtube { background: #ff0033; }
  .tl-badge--tiktok  { background: #25f4ee; color: #000; }
  .tl-body {
    flex: 1;
    padding: 0.9rem 1.1rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .tl-meta {
    font-size: 0.82rem;
    color: var(--fg-muted);
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .tl-tag {
    background: rgba(192, 132, 252, 0.14);
    color: #d4b8fc;
    padding: 0.12rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  /* Mobile-only date pill (hidden on desktop, where the date sits in the left gutter). */
  .tl-mobile-date {
    display: none;
    background: var(--bg-elev-2);
    color: var(--fg);
    padding: 0.12rem 0.55rem;
    border-radius: 999px;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .tl-creator {
    font-weight: 600;
    color: var(--fg);
  }
  .tl-title {
    margin: 0;
    font-size: 1.05rem;
    line-height: 1.35;
  }
  .tl-desc {
    margin: 0;
    font-size: 0.9rem;
    color: var(--fg-muted);
  }

  @media (max-width: 720px) {
    .tl-item {
      grid-template-columns: 18px 1fr;
      padding: 0.6rem 0;
    }
    /* Hide the left date column on mobile — the date moves into the card meta. */
    .tl-when { display: none; }
    .tl-dot {
      margin-top: 0.85rem;
      margin-left: 3px;
    }
    .tl-card {
      margin-left: 0.7rem;
      flex-direction: row;
      gap: 0.7rem;
    }
    .tl-thumb {
      flex: 0 0 110px;
      aspect-ratio: 1 / 1;
      border-radius: 8px 0 0 8px;
    }
    .tl-body {
      padding: 0.6rem 0.7rem 0.6rem 0;
    }
    .tl-title {
      font-size: 0.95rem;
    }
    .tl-desc {
      display: none; /* save vertical space on mobile */
    }
    .tl-mobile-date {
      display: inline-block;
    }
    .tl-meta {
      gap: 0.4rem;
      font-size: 0.78rem;
    }
    .tl-badge {
      top: 0.3rem;
      left: 0.3rem;
      font-size: 0.6rem;
      padding: 0.1rem 0.4rem;
    }
  }
</style>
