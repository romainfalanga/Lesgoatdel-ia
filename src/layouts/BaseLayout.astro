---
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = 'Les GOATs de l\'IA',
  description = 'Le récap quotidien des meilleurs créateurs de contenu IA — articles générés à partir de leurs vidéos.',
  ogImage,
} = Astro.props;

const fullTitle = title === 'Les GOATs de l\'IA' ? title : `${title} · Les GOATs de l'IA`;
const canonical = new URL(Astro.url.pathname, Astro.site ?? 'https://lesgoatsdelia.netlify.app').toString();
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Ctext y='52' font-size='52'%3E%F0%9F%90%90%3C/text%3E%3C/svg%3E" />
    <link rel="alternate" type="application/rss+xml" title="Les GOATs de l'IA" href="/rss.xml" />
  </head>
  <body>
    <header class="site-header">
      <div class="container">
        <a href="/" class="brand" aria-label="Accueil">
          <span class="brand-emoji">🐐</span>
          <span>Les <span class="brand-accent">GOATs</span> de l'IA</span>
        </a>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <div>
          🐐 Les GOATs de l'IA — articles générés automatiquement à partir des vidéos publiques des créateurs.
        </div>
        <div>© {new Date().getFullYear()}</div>
      </div>
    </footer>
  </body>
</html>
